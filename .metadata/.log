		p.add(new JLabel("영어"));
		p.add(e2);
		p.add(new JLabel("수학"));
		p.add(e3);
		p.add(button);
		
		contentpane.add(p, BorderLayout.SOUTH);
		button.addActionListener(new DrawingActionListener(e1, e2, e3, resultPanel));
